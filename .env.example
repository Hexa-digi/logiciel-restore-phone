# Base de donnees PostgreSQL. En local avec Docker : docker compose up -d db, puis
# DATABASE_URL="postgresql://nexus:motdepasse@localhost:5432/nexus"
# En production (Vercel, VPS...) : URL fournie par votre hebergeur Postgres (Neon, Supabase...).
DATABASE_URL="postgresql://user:password@localhost:5432/nexus"

# Cle API Anthropic pour l'assistant IA (https://console.anthropic.com/)
ANTHROPIC_API_KEY=""

# Serveur SMTP pour l'envoi reel d'emails depuis l'app (optionnel).
# Exemple avec Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=votre@gmail.com,
# SMTP_PASSWORD=mot de passe d'application (pas votre mot de passe Gmail habituel).
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM=""

# Secret utilise pour signer les sessions (genere une chaine aleatoire longue)
AUTH_SECRET="change-moi-en-une-chaine-aleatoire-longue"

# Identifiants du compte unique de l'application
APP_OWNER_EMAIL="contact.hexadigi@gmail.com"
APP_OWNER_PASSWORD="change-moi"

# Nom de l'entreprise affiche dans l'app
COMPANY_NAME="Hexa Digi"
